<IfModule mod_rewrite.c>
    RewriteEngine On

    # Empêcher les requêtes sur des fichiers/répertoires réels
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Page d'accueil
    RewriteRule ^/?$ index.php [L]

    # Sitemap
    RewriteRule ^sitemap\.xml/?$ sitemap.xml.php [L]

    # Article: /article/mon-slug-ici
    RewriteRule ^article/([a-z0-9\-]+)/?$ pages/article.php?slug=$1 [L,QSA]

    # Catégorie: /categorie/mon-slug-ici
    RewriteRule ^categorie/([a-z0-9\-]+)/?$ pages/categorie.php?slug=$1 [L,QSA]

    # Tag: /tag/mon-slug
    RewriteRule ^tag/([a-z0-9\-]+)/?$ pages/tag.php?slug=$1 [L,QSA]

    # Auteur: /auteur/mon-slug
    RewriteRule ^auteur/([a-z0-9\-]+)/?$ pages/auteur.php?slug=$1 [L,QSA]

    # Admin: /admin/login, /admin/dashboard, /admin/articles/new, etc
    RewriteRule ^admin/login/?$ admin/index.php?page=login [L,QSA]
    RewriteRule ^admin/logout/?$ admin/index.php?page=logout [L,QSA]
    RewriteRule ^admin/dashboard/?$ admin/index.php?page=dashboard [L,QSA]
    RewriteRule ^admin/articles/?$ admin/index.php?page=articles [L,QSA]
    RewriteRule ^admin/articles/new/?$ admin/index.php?page=articles&action=new [L,QSA]
    RewriteRule ^admin/articles/edit/([0-9]+)/?$ admin/index.php?page=articles&action=edit&id=$1 [L,QSA]
    RewriteRule ^admin/categories/?$ admin/index.php?page=categories [L,QSA]
    RewriteRule ^admin/categories/new/?$ admin/index.php?page=categories&action=new [L,QSA]
    RewriteRule ^admin/categories/edit/([0-9]+)/?$ admin/index.php?page=categories&action=edit&id=$1 [L,QSA]
    RewriteRule ^admin/tags/?$ admin/index.php?page=tags [L,QSA]
    RewriteRule ^admin/tags/new/?$ admin/index.php?page=tags&action=new [L,QSA]
    RewriteRule ^admin/tags/edit/([0-9]+)/?$ admin/index.php?page=tags&action=edit&id=$1 [L,QSA]
    RewriteRule ^admin/auteurs/?$ admin/index.php?page=auteurs [L,QSA]
    RewriteRule ^admin/auteurs/new/?$ admin/index.php?page=auteurs&action=new [L,QSA]
    RewriteRule ^admin/auteurs/edit/([0-9]+)/?$ admin/index.php?page=auteurs&action=edit&id=$1 [L,QSA]
</IfModule>

# ===== COMPRESSION GZIP =====
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/font-woff
    AddOutputFilterByType DEFLATE application/font-woff2
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ===== MISE EN CACHE FICHIERS STATIQUES =====
<IfModule mod_expires.c>
    ExpiresActive On

    # Images (1 mois)
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"

    # CSS & JS (1 mois)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"

    # Fonts (1 an)
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"

    # Par défaut (no cache pour les pages HTML)
    ExpiresDefault "access plus 0 seconds"
</IfModule>

# ===== HEADERS CACHE =====
<IfModule mod_headers.c>
    # Images
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>

    # CSS & JS
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>

    # Fonts
    <FilesMatch "\.(woff|woff2|ttf|otf)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>

    # HTML (no cache)
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>
